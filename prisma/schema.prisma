generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Tank {
  id           String   @id @default(cuid())
  name         String
  volumeLiters Int
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
